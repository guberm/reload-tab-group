{
  "manifest_version": 3,
  "name": "Reload Tab Group",
  "version": "1.0.0",
  "description": "Reload every tab in the active tab group with one click.",
  "minimum_chrome_version": "88",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Reload all tabs in this group",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
